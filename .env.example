# Supabase URL from your project dashboard
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon Key from your project dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (Keep this secret, never expose to client!)
SUPABASE_SERVICE_ROLE_KEY=

# Liveblocks Public Key

# Liveblocks Secret Key (Server only)
LIVEBLOCKS_SECRET_KEY=

# Base URL of the app
NEXT_PUBLIC_APP_URL=
GEMINI_API_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Sentry — Error monitoring (E2EE-safe: only stack traces, no payloads)
# Get DSN from sentry.io → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source map upload (CI/Vercel only — not needed locally)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
